(version 1)
(rule "CPU BGA fanout"
   (layer outer)
   (constraint track_width (min 0.127mm) (opt 0.154mm))
   (constraint clearance (min 0.1016mm) (opt 0.154mm))
   (condition "A.insideCourtyard('U1')"))
(rule "DRAM BGA fanout"
   (layer outer)
   (constraint track_width (min 0.127mm) (opt 0.154mm))
   (constraint clearance (min 0.1016mm) (opt 0.154mm))
   (condition "A.insideCourtyard('U2')"))
